<?xml version="1.0" encoding="utf-8"?>
<!-- Legacy fallback for API 24-25 (pre-adaptive icons). Combines background and
     foreground into a single vector so the launcher gets a complete bitmap. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Background -->
    <path
        android:fillColor="#3949AB"
        android:pathData="M0,0 H108 V108 H0 Z" />

    <!-- Magnifying-glass handle -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="13"
        android:strokeLineCap="round"
        android:pathData="M60,60 L85,85" />

    <!-- Lens -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M22,44 a22,22 0 1 0 44,0 a22,22 0 1 0 -44,0 Z" />

    <!-- Letter E -->
    <path
        android:fillColor="#3949AB"
        android:pathData="M35,33 H53 V37 H39 V41 H49 V45 H39 V51 H53 V55 H35 Z" />
</vector>
